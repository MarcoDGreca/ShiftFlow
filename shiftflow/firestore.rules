rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    // "Dichiara di appartenere" al locale: lo dice il suo profilo users.
    // Da sola NON basta per accedere ai dati: la rimozione dall'anagrafica
    // non può toccare users/{uid} (serverebbe un backend), quindi...
    function isMember(restaurantId) {
      return isSignedIn() && userDoc().restaurantId == restaurantId;
    }
    // ...l'appartenenza EFFETTIVA richiede anche il documento staff: è quello
    // che il responsabile elimina quando rimuove un membro. Senza, niente
    // accesso ai dati del locale (turni, richieste, anagrafica).
    function hasStaffDoc(restaurantId) {
      return exists(/databases/$(database)/documents/restaurants/$(restaurantId)/staff/$(request.auth.uid));
    }
    // Il PROPRIETARIO del locale (campo ownerUid del documento ristorante) non
    // può essere rimosso da nessuno: il suo accesso NON deve dipendere dal
    // documento staff, altrimenti un locale senza quel doc lo chiuderebbe fuori
    // dai propri dati (e non potrebbe nemmeno ricrearlo: chicken-and-egg).
    // È la fonte di verità sulla proprietà, quindi lo trattiamo sempre come staff.
    function isOwner(restaurantId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/restaurants/$(restaurantId))
        && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid;
    }
    function isStaff(restaurantId) {
      return isOwner(restaurantId)
        || (isMember(restaurantId) && hasStaffDoc(restaurantId));
    }
    function isResponsabile(restaurantId) {
      return isStaff(restaurantId) && userDoc().role == "responsabile";
    }

    match /users/{uid} {
      allow read:   if isSignedIn() && request.auth.uid == uid;
      // creazione del proprio profilo in fase di registrazione
      allow create: if isSignedIn() && request.auth.uid == uid;
      // l'utente può aggiornare il proprio documento, ma NON ruolo e ristorante:
      // sono la base dell'autorizzazione, non deve potersi auto-promuovere né
      // spostarsi in un altro locale.
      allow update: if isSignedIn() && request.auth.uid == uid
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.restaurantId == resource.data.restaurantId;
      allow delete: if false;
    }

    match /restaurants/{restaurantId} {
      allow read: if isStaff(restaurantId);
      // Creazione SOLO in fase di registrazione: l'utente è nuovo (non ha
      // ancora un profilo users) e intesta il locale a se stesso. La
      // registrazione scrive nell'ordine locale → staff → users, così l'app
      // entra nella home solo quando tutto esiste già.
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && !exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update, delete: if isResponsabile(restaurantId);

      match /staff/{uid} {
        // Ognuno può leggere il PROPRIO documento staff anche se assente: il
        // gate dell'app lo osserva per capire se il membro è stato rimosso.
        // Per leggere quelli degli altri serve l'appartenenza effettiva.
        allow read: if isStaff(restaurantId)
                     || (isMember(restaurantId) && request.auth.uid == uid);
        // Il responsabile gestisce l'anagrafica; il proprietario appena
        // registrato (ancora senza profilo users) crea il proprio ingresso.
        allow create: if isResponsabile(restaurantId)
                       || (request.auth.uid == uid
                           && get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid);
        allow update, delete: if isResponsabile(restaurantId);
      }
      match /shifts/{shiftId} {
        allow read: if isStaff(restaurantId);
        allow create, update, delete: if isResponsabile(restaurantId);
      }
      match /leaveRequests/{requestId} {
        // Il responsabile vede tutte le richieste del locale; il dipendente solo
        // le PROPRIE. Così nessun dipendente accede alle motivazioni (reason)
        // delle richieste altrui (RNF8, seconda clausola).
        allow read: if isResponsabile(restaurantId)
                     || (isStaff(restaurantId)
                         && resource.data.employeeUid == request.auth.uid);
        // Il dipendente crea SOLO richieste "in attesa": lo stato iniziale non è
        // negoziabile. Senza questo vincolo potrebbe nascere una richiesta già
        // "approvata" (auto-concessione di ferie/permessi) o con un esito e un
        // "resolvedBy" falsi, scavalcando la decisione del responsabile (RF6).
        allow create: if isStaff(restaurantId)
                       && request.resource.data.employeeUid == request.auth.uid
                       && request.resource.data.status == "in_attesa";
        // Il responsabile decide (approva/rifiuta). Il dipendente può SOLO
        // annullare la PROPRIA richiesta, e solo finché è ancora "in attesa".
        // Nell'annullamento l'UNICO campo che può cambiare è "status": così non
        // può, con la stessa scrittura, riscrivere employeeUid (spostando la
        // richiesta nello storico di un collega), motivazione o date.
        allow update: if isResponsabile(restaurantId)
                       || (isStaff(restaurantId)
                           && resource.data.employeeUid == request.auth.uid
                           && resource.data.status == "in_attesa"
                           && request.resource.data.status == "annullata"
                           && request.resource.data.diff(resource.data)
                                .affectedKeys().hasOnly(["status"]));
      }
    }
  }
}
